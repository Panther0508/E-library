# =============================================================================
# EngineerVault Environment Variables
# =============================================================================

# =============================================================================
# Supabase Configuration
# =============================================================================
# Get these from your Supabase project dashboard at https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: For server-side operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# Remotive API Configuration
# =============================================================================
# Remotive API URL (optional - defaults to https://remotive.com/api/remote-jobs)
REMOTIVE_API_URL=https://remotive.com/api/remote-jobs

# =============================================================================
# HuggingFace AI Configuration
# =============================================================================
# Get your API token from https://huggingface.co/settings/tokens
# Required for AI-powered features
HUGGINGFACE_API_TOKEN=your-huggingface-token-here

# =============================================================================
# Vercel Frontend Configuration
# =============================================================================
# Your Vercel frontend URL (for CORS configuration)
# Example: https://your-project.vercel.app
VERCEL_FRONTEND_URL=

# =============================================================================
# API Configuration
# =============================================================================
# API Version
API_VERSION=1.0.0

# Next.js Configuration
NEXT_PUBLIC_API_URL=/api

# =============================================================================
# Cache Configuration
# =============================================================================
# Cache TTL in seconds (optional - defaults are set in code)
# CACHE_TTL_JOBS=180
# CACHE_TTL_CATEGORIES=900
# CACHE_TTL_SEARCH=120

# =============================================================================
# Rate Limiting Configuration
# =============================================================================
# Rate limit configuration (optional - defaults are set in code)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=30
# RATE_LIMIT_SEARCH_MAX=10

# =============================================================================
# Logging Configuration
# =============================================================================
# Enable detailed logging (true/false)
LOGGING_ENABLED=true

# =============================================================================
# Node Environment
# =============================================================================
# Set to 'production' in production
NODE_ENV=development
